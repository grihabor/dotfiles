#!/usr/bin/env bash

set -euo pipefail

FD=fd

for cmd in "$FD" tmux fzf; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        printf 'error: %s not found in PATH\n' "$cmd" >&2
        exit 1
    fi
done

fzf_exit_code=0
PROJECT_ROOT=$($FD --hidden --regex "^\.git$" \
    --exclude .cargo \
    --exclude .local \
    --exclude .cache \
    --exclude .tmux \
    --min-depth 2 \
    --max-depth 5 \
    "$HOME" |
    xargs dirname |
    fzf) || fzf_exit_code=$?

if [ $fzf_exit_code -ne 0 ]; then
    printf "fzf exit code %d\n" $fzf_exit_code
    exit 1
fi

# If the chosen dir is a git worktree, name it <bare-repo-name>_<worktree-name>
GIT_COMMON_DIR=$(git -C "$PROJECT_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || true
GIT_DIR=$(git -C "$PROJECT_ROOT" rev-parse --path-format=absolute --absolute-git-dir 2>/dev/null) || true
if [ -n "$GIT_COMMON_DIR" ] && [ "$GIT_COMMON_DIR" != "$GIT_DIR" ]; then
    # common dir is the repo itself (bare) or /path/to/<repo>/.git (non-bare)
    BARE_NAME=$(basename "$GIT_COMMON_DIR")
    if [ "$BARE_NAME" = ".git" ]; then
        BARE_NAME=$(basename "$(dirname "$GIT_COMMON_DIR")")
    fi
    WORKTREE_NAME=$(basename "$PROJECT_ROOT")
    NAME="${BARE_NAME}_${WORKTREE_NAME}"
else
    # normal repo (or not a bare repo): name it after the dir
    NAME=$(basename "$PROJECT_ROOT")
fi

if ! tmux has-session -t="$NAME" 2>/dev/null; then
    echo "Creating session $NAME"
    # Always create the session detached so we can send keys to it before
    # attaching. If created attached, new-session would block until the
    # session ends and send-keys would never run in time.
    tmux new-session -d \
        -c "$PROJECT_ROOT" \
        -s "$NAME"
    # Open nvim in the project dir only in the first window of the session.
    tmux send-keys -t "$NAME" 'nvim .' Enter
fi
if [ "${TMUX:-}" == "" ]; then
    tmux attach -t "$NAME"
else
    tmux switch-client -t "$NAME"
fi
